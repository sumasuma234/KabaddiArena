<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/kabaddiImage"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/kabaddi_bg"
            android:scaleType="centerCrop"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kabaddi Arena"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/playerNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Player Name"
            android:textSize="22sp"
            android:padding="10dp"
            android:layout_marginBottom="25dp"/>

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score: 0"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#444444"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/raidSuccessBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RAID SUCCESS (+2)"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/emptyRaidBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMPTY RAID (+0)"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/tackleSuccessBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TACKLE SUCCESS (+1)"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/undoBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UNDO"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/resetBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESET"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/resultBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SHOW RESULT"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>

</ScrollView>